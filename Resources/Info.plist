<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Menu bar only — hides from Dock -->
    <key>LSUIElement</key>
    <true/>

    <!-- Bundle identity -->
    <key>CFBundleName</key>
    <string>Easy Sleep &amp; Shutdown</string>
    <key>CFBundleDisplayName</key>
    <string>Easy Sleep &amp; Shutdown</string>
    <key>CFBundleIdentifier</key>
    <string>com.easysleepshutdown.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleExecutable</key>
    <string>EasySleepShutdown</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>

    <!-- App icon (set in Xcode asset catalog) -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>

    <!-- Copyright -->
    <key>NSHumanReadableCopyright</key>
    <string>© 2025 Easy Sleep &amp; Shutdown. All rights reserved.</string>

    <!-- macOS 10.14+: required usage description for Apple Events -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Easy Sleep &amp; Shutdown uses Apple Events to put your Mac to sleep or shut it down after the selected delay.</string>

    <!-- Minimum macOS version -->
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <!-- App Store category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
</dict>
</plist>
